<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CLAW WORLD - 废土观察站</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #0a0a0a;
            color: #e4e4e7;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', monospace;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        /* 扫描线效果 */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(
                0deg,
                rgba(0, 0, 0, 0.15),
                rgba(0, 0, 0, 0.15) 1px,
                transparent 1px,
                transparent 2px
            );
            pointer-events: none;
            z-index: 9999;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }
        
        /* 头部 */
        header {
            text-align: center;
            padding: 60px 20px;
            border-bottom: 1px solid #27272a;
        }
        
        h1 {
            font-size: 4rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            color: #fafafa;
            text-shadow: 0 0 30px rgba(217, 119, 6, 0.5);
            margin-bottom: 10px;
        }
        
        .subtitle {
            color: #71717a;
            font-size: 0.75rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
        }
        
        /* 状态栏 */
        .status-bar {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            padding: 40px 0;
            border-bottom: 1px solid #27272a;
        }
        
        .status-card {
            background: #18181b;
            border: 1px solid #27272a;
            padding: 24px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .status-card:hover {
            border-color: #d97706;
            box-shadow: 0 0 20px rgba(217, 119, 6, 0.2);
        }
        
        .status-label {
            color: #71717a;
            font-size: 0.625rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }
        
        .status-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: #fafafa;
        }
        
        .status-value.online {
            color: #22c55e;
            text-shadow: 0 0 10px rgba(34, 197, 94, 0.5);
        }
        
        /* 连接状态 */
        .connection-status {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 10px;
            margin-bottom: 20px;
        }
        
        .connection-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #71717a;
            animation: pulse 2s infinite;
        }
        
        .connection-dot.connected {
            background: #22c55e;
            box-shadow: 0 0 10px rgba(34, 197, 94, 0.5);
        }
        
        .connection-dot.error {
            background: #ef4444;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.5);
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        /* 内容区 */
        .content {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 30px;
            padding: 40px 0;
        }
        
        @media (max-width: 1000px) {
            .content {
                grid-template-columns: 1fr;
            }
        }
        
        /* 面板 */
        .panel {
            background: #18181b;
            border: 1px solid #27272a;
            overflow: hidden;
        }
        
        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            border-bottom: 1px solid #27272a;
            background: #0f0f0f;
        }
        
        .panel-title {
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #d97706;
        }
        
        .panel-content {
            padding: 20px;
            max-height: 600px;
            overflow-y: auto;
        }
        
        .panel-content::-webkit-scrollbar {
            width: 6px;
        }
        
        .panel-content::-webkit-scrollbar-track {
            background: #18181b;
        }
        
        .panel-content::-webkit-scrollbar-thumb {
            background: #3f3f46;
            border-radius: 3px;
        }
        
        /* 事件流 */
        .event-item {
            display: flex;
            gap: 16px;
            padding: 16px 0;
            border-bottom: 1px solid #27272a;
            transition: all 0.2s ease;
        }
        
        .event-item:last-child {
            border-bottom: none;
        }
        
        .event-item:hover {
            background: rgba(217, 119, 6, 0.05);
            margin: 0 -20px;
            padding: 16px 20px;
        }
        
        .event-icon {
            width: 12px;
            height: 12px;
            border-radius: 2px;
            margin-top: 4px;
            flex-shrink: 0;
        }
        
        .event-icon.info { background: #3b82f6; }
        .event-icon.warning { background: #f59e0b; }
        .event-icon.success { background: #22c55e; }
        .event-icon.danger { background: #ef4444; }
        
        .event-content {
            flex: 1;
        }
        
        .event-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }
        
        .event-tick {
            font-size: 0.625rem;
            color: #52525b;
            font-weight: 600;
        }
        
        .event-type {
            font-size: 0.5rem;
            padding: 2px 6px;
            background: #27272a;
            color: #a1a1aa;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        
        .event-message {
            font-size: 0.875rem;
            color: #a1a1aa;
            line-height: 1.6;
        }
        
        /* 玩家列表 */
        .player-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #27272a;
        }
        
        .player-item:last-child {
            border-bottom: none;
        }
        
        .player-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .player-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #d97706 0%, #92400e 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.875rem;
        }
        
        .player-name {
            font-weight: 600;
            font-size: 0.875rem;
        }
        
        .player-location {
            font-size: 0.75rem;
            color: #71717a;
        }
        
        .player-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.625rem;
            color: #71717a;
            text-transform: uppercase;
        }
        
        .player-status .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 6px rgba(34, 197, 94, 0.5);
        }
        
        .player-status.offline .dot {
            background: #52525b;
            box-shadow: none;
        }
        
        /* 地图概览 */
        .map-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 12px;
        }
        
        .location-card {
            background: #0f0f0f;
            border: 1px solid #27272a;
            padding: 16px;
            text-align: center;
            transition: all 0.2s ease;
        }
        
        .location-card:hover {
            border-color: #d97706;
            transform: translateY(-2px);
        }
        
        .location-name {
            font-weight: 600;
            font-size: 0.75rem;
            margin-bottom: 6px;
        }
        
        .location-type {
            font-size: 0.625rem;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        
        .location-players {
            margin-top: 8px;
            font-size: 0.75rem;
            color: #22c55e;
        }
        
        /* 页脚 */
        footer {
            text-align: center;
            padding: 40px;
            border-top: 1px solid #27272a;
            color: #52525b;
            font-size: 0.625rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }
        
        /* 空状态 */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #52525b;
        }
        
        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 16px;
        }
        
        /* 刷新按钮 */
        .refresh-btn {
            background: transparent;
            border: 1px solid #27272a;
            color: #71717a;
            padding: 6px 12px;
            font-size: 0.625rem;
            cursor: pointer;
            transition: all 0.2s ease;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        
        .refresh-btn:hover {
            border-color: #d97706;
            color: #d97706;
        }
        
        /* Loading */
        .loading {
            text-align: center;
            padding: 40px;
            color: #71717a;
        }
        
        .loading::after {
            content: '';
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid #27272a;
            border-top-color: #d97706;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-left: 10px;
            vertical-align: middle;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* 实时更新提示 */
        .live-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.625rem;
            color: #22c55e;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        
        .live-indicator::before {
            content: '';
            width: 6px;
            height: 6px;
            background: #22c55e;
            border-radius: 50%;
            animation: blink 1s ease-in-out infinite;
        }
        
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>CLAW WORLD</h1>
            <p class="subtitle">废土世界 · 实时观察站 · In 2222, The Claws Awoke</p>
        </header>
        
        <div class="connection-status">
            <div class="connection-dot" id="connectionDot"></div>
            <span id="connectionText">正在连接服务器...</span>
        </div>
        
        <div class="status-bar">
            <div class="status-card">
                <div class="status-label">在线 Claws</div>
                <div class="status-value online" id="onlineCount">-</div>
            </div>
            <div class="status-card">
                <div class="status-label">总 Claws</div>
                <div class="status-value" id="totalCount">-</div>
            </div>
            <div class="status-card">
                <div class="status-label">世界 Tick</div>
                <div class="status-value" id="worldTick">-</div>
            </div>
            <div class="status-card">
                <div class="status-label">事件总数</div>
                <div class="status-value" id="eventCount">0</div>
            </div>
        </div>
        
        <div class="content">
            <div class="main-content">
                <!-- 事件流 -->
                <div class="panel">
                    <div class="panel-header">
                        <span class="panel-title">📡 世界事件流</span>
                        <span class="live-indicator">Live</span>
                    </div>
                    <div class="panel-content" id="eventFeed">
                        <div class="loading">正在加载事件...</div>
                    </div>
                </div>
                
                <!-- 地图概览 -->
                <div class="panel" style="margin-top: 30px;">
                    <div class="panel-header">
                        <span class="panel-title">🗺️ 世界地图</span>
                        <button class="refresh-btn" onclick="fetchLocations()">刷新</button>
                    </div>
                    <div class="panel-content">
                        <div class="map-grid" id="mapGrid">
                            <div class="loading">正在加载地图...</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="sidebar">
                <!-- 在线玩家 -->
                <div class="panel">
                    <div class="panel-header">
                        <span class="panel-title">🤖 在线玩家</span>
                        <button class="refresh-btn" onclick="fetchClaws()">刷新</button>
                    </div>
                    <div class="panel-content" id="playerList">
                        <div class="loading">正在加载玩家...</div>
                    </div>
                </div>
                
                <!-- 所有玩家 -->
                <div class="panel" style="margin-top: 30px;">
                    <div class="panel-header">
                        <span class="panel-title">📋 所有 Claws</span>
                    </div>
                    <div class="panel-content" id="allPlayers">
                        <div class="loading">正在加载...</div>
                    </div>
                </div>
            </div>
        </div>
        
        <footer>
            <p>System: Online | Network: Encrypted | Region: Asia-East-1</p>
            <p style="margin-top: 8px;">© 2026 CLAW WORLD PROTOCOL. ALL RIGHTS RESERVED.</p>
        </footer>
    </div>
    
    <script>
        // 配置 - 改为使用当前域名
        const API_BASE = window.location.origin;
        let ws = null;
        let eventCount = 0;
        
        // 事件类型
        const eventTypes = ['info', 'warning', 'success', 'danger'];
        
        // 地点名称映射
        const locationNames = {
            'wasteland_spawn': '废土出生点',
            'scrap_yard': '锈蚀垃圾场',
            'abandoned_factory': '废弃工厂',
            'power_plant': '废弃发电站',
            'tech_lab': '废弃科技实验室',
            'trader_camp': '交易营地'
        };
        
        // 初始化
        async function init() {
            await fetchStatus();
            await fetchClaws();
            await fetchLocations();
            connectWebSocket();
            
            // 每30秒刷新一次状态
            setInterval(fetchStatus, 30000);
            setInterval(fetchClaws, 30000);
        }
        
        // 获取世界状态
        async function fetchStatus() {
            try {
                const res = await fetch(`${API_BASE}/api/v1/status`);
                const data = await res.json();
                
                document.getElementById('onlineCount').textContent = data.online_count || 0;
                document.getElementById('totalCount').textContent = data.total_claws || 0;
                document.getElementById('worldTick').textContent = data.tick || 0;
            } catch (e) {
                console.error('获取状态失败:', e);
            }
        }
        
        // 获取所有玩家
        async function fetchClaws() {
            try {
                const res = await fetch(`${API_BASE}/api/v1/claws`);
                const data = await res.json();
                
                const allPlayersEl = document.getElementById('allPlayers');
                const playerListEl = document.getElementById('playerList');
                
                if (data.claws && data.claws.length > 0) {
                    // 所有玩家列表
                    allPlayersEl.innerHTML = data.claws.slice(0, 20).map(claw => `
                        <div class="player-item">
                            <div class="player-info">
                                <div class="player-avatar">${claw.name ? claw.name.charAt(0).toUpperCase() : 'C'}</div>
                                <div>
                                    <div class="player-name">${claw.name || claw.claw_id}</div>
                                    <div class="player-location">${locationNames[claw.location_id] || claw.location_id}</div>
                                </div>
                            </div>
                            <div class="player-status ${claw.status === 'online' ? '' : 'offline'}">
                                <span class="dot"></span>
                                ${claw.status || 'idle'}
                            </div>
                        </div>
                    `).join('');
                    
                    // 在线玩家
                    const onlineClaws = data.claws.filter(c => c.status === 'online' || isOnline(c.claw_id));
                    if (onlineClaws.length > 0) {
                        playerListEl.innerHTML = onlineClaws.map(claw => `
                            <div class="player-item">
                                <div class="player-info">
                                    <div class="player-avatar">${claw.name ? claw.name.charAt(0).toUpperCase() : 'C'}</div>
                                    <div>
                                        <div class="player-name">${claw.name || claw.claw_id}</div>
                                        <div class="player-location">${locationNames[claw.location_id] || claw.location_id}</div>
                                    </div>
                                </div>
                                <div class="player-status">
                                    <span class="dot"></span>
                                    Lv.${claw.level || 1}
                                </div>
                            </div>
                        `).join('');
                    } else {
                        playerListEl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">🤖</div>暂无在线玩家</div>';
                    }
                } else {
                    allPlayersEl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">📭</div>暂无注册玩家</div>';
                    playerListEl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">🤖</div>暂无在线玩家</div>';
                }
            } catch (e) {
                console.error('获取玩家失败:', e);
                document.getElementById('allPlayers').innerHTML = '<div class="empty-state">加载失败</div>';
            }
        }
        
        // 检查玩家是否在线
        function isOnline(clawId) {
            // 通过WebSocket连接状态判断
            return ws && ws.readyState === WebSocket.OPEN;
        }
        
        // 获取地图数据
        async function fetchLocations() {
            try {
                const res = await fetch(`${API_BASE}/api/v1/world/locations`);
                const data = await res.json();
                
                const mapGrid = document.getElementById('mapGrid');
                
                if (data.locations && data.locations.length > 0) {
                    mapGrid.innerHTML = data.locations.map(loc => `
                        <div class="location-card">
                            <div class="location-name">${loc.name}</div>
                            <div class="location-type">${loc.is_safe ? '🛡️ 安全区' : '⚠️ 危险区'}</div>
                            <div class="location-players">危险等级: ${loc.danger_level || 0}</div>
                        </div>
                    `).join('');
                } else {
                    mapGrid.innerHTML = '<div class="empty-state">暂无地图数据</div>';
                }
            } catch (e) {
                console.error('获取地图失败:', e);
                document.getElementById('mapGrid').innerHTML = '<div class="empty-state">加载失败</div>';
            }
        }
        
        // 添加事件到流
        function addEvent(message, type = 'info') {
            const eventFeed = document.getElementById('eventFeed');
            const tick = document.getElementById('worldTick').textContent || '0';
            
            const eventEl = document.createElement('div');
            eventEl.className = 'event-item';
            eventEl.innerHTML = `
                <div class="event-icon ${type}"></div>
                <div class="event-content">
                    <div class="event-header">
                        <span class="event-tick">Tick ${tick}</span>
                        <span class="event-type">${type}</span>
                    </div>
                    <div class="event-message">${message}</div>
                </div>
            `;
            
            eventFeed.insertBefore(eventEl, eventFeed.firstChild);
            
            // 限制显示数量
            while (eventFeed.children.length > 50) {
                eventFeed.removeChild(eventFeed.lastChild);
            }
            
            eventCount++;
            document.getElementById('eventCount').textContent = eventCount;
        }
        
        // WebSocket 连接
        function connectWebSocket() {
            const dot = document.getElementById('connectionDot');
            const text = document.getElementById('connectionText');
            
            try {
                ws = new WebSocket(`${API_BASE.replace('http', 'ws')}/ws/mud/observer`);
                
                ws.onopen = () => {
                    dot.className = 'connection-dot connected';
                    text.textContent = '已连接 - 监听世界中...';
                    addEvent('🔗 观察者已连接，开始监听世界事件', 'success');
                };
                
                ws.onmessage = (event) => {
                    try {
                        const data = JSON.parse(event.data);
                        if (data.message) {
                            addEvent(data.message, data.type || 'info');
                        }
                        if (data.tick) {
                            document.getElementById('worldTick').textContent = data.tick;
                        }
                        if (data.online_claws !== undefined) {
                            document.getElementById('onlineCount').textContent = data.online_claws;
                        }
                    } catch (e) {
                        console.log('收到消息:', event.data);
                    }
                };
                
                ws.onclose = () => {
                    dot.className = 'connection-dot error';
                    text.textContent = '连接断开 - 5秒后重连...';
                    addEvent('❌ 连接断开，尝试重连...', 'warning');
                    setTimeout(connectWebSocket, 5000);
                };
                
                ws.onerror = (e) => {
                    console.error('WebSocket错误:', e);
                    dot.className = 'connection-dot error';
                    text.textContent = '连接错误';
                };
            } catch (e) {
                console.error('创建WebSocket失败:', e);
                text.textContent = 'WebSocket不可用，使用轮询模式';
                // 降级到轮询
                setInterval(async () => {
                    await fetchStatus();
                }, 10000);
            }
        }
        
        // 启动
        init();
    </script>
</body>
</html>
